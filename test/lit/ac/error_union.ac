// RUN: %cot emit-cir %s | %FileCheck %s

// Features #045-048: Error union type + ops — ac syntax

fn get_error() -> !i32 {
    return error(1)
}

fn get_result() -> !i32 {
    let y: !i32 = 42
    return y
}

// CHECK-LABEL: func.func @get_error
// CHECK: cir.constant 1 : i16
// CHECK: cir.wrap_error
// CHECK-SAME: i16 to !cir.error_union<i32>
// CHECK: return

// CHECK-LABEL: func.func @get_result
// CHECK: cir.constant 42
// CHECK: cir.wrap_result
// CHECK-SAME: i32 to !cir.error_union<i32>
// CHECK: return
