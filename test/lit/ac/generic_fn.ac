// RUN: %cot emit-cir %s | %FileCheck %s

// Feature #055: Generic function — ac syntax

fn max[T](a: T, b: T) -> T {
    if a > b {
        return a
    }
    return b
}

fn main() -> i32 {
    return max[i32](3, 7)
}

// Frontend monomorphizes: max[i32] → max_i32
// CHECK-LABEL: func.func @max_i32
// CHECK: cir.cmp sgt
// CHECK: return

// CHECK-LABEL: func.func @main
// CHECK: call @max_i32
// CHECK: return
