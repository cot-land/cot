// RUN: %cot emit-cir %s | %FileCheck %s

// Feature #055: Generic function — ac syntax
// Frontend emits !cir.type_param + cir.generic_apply.
// GenericSpecializer pass resolves before output.

fn identity[T](x: T) -> T {
    return x
}

fn main() -> i32 {
    return identity[i32](42)
}

// After specialization: main calls identity_i32
// CHECK-LABEL: func.func @main
// CHECK: call @identity_i32
// CHECK: return

// Specialized function
// CHECK-LABEL: func.func @identity_i32
// CHECK-SAME: i32
// CHECK: return
