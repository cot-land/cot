// RUN: %cot emit-cir %s | %FileCheck %s

// Features #049-050: Enum type + value — ac syntax

enum Color { Red, Green, Blue }

fn get_red() -> Color {
    return Color.Red
}

fn get_blue() -> Color {
    return Color.Blue
}

fn color_to_int(c: Color) -> i32 {
    return c as i32
}

// CHECK-LABEL: func.func @get_red
// CHECK: cir.enum_constant "Red" : !cir.enum<"Color"
// CHECK: return

// CHECK-LABEL: func.func @get_blue
// CHECK: cir.enum_constant "Blue" : !cir.enum<"Color"
// CHECK: return

// CHECK-LABEL: func.func @color_to_int
// CHECK: cir.enum_value
// CHECK: return
