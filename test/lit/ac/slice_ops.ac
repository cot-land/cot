// RUN: %cot emit-cir %s | %FileCheck %s

// Features #037-040: Slice operations — ac syntax

fn get_len() -> i64 {
    let s: string = "hello"
    return s.len
}

fn get_char() -> i8 {
    let s: string = "hello"
    let idx: i64 = 0
    return s[idx]
}

// CHECK-LABEL: func.func @get_len
// CHECK: cir.string_constant "hello" : !cir.slice<i8>
// CHECK: cir.slice_len
// CHECK-SAME: !cir.slice<i8> to i64
// CHECK: return

// CHECK-LABEL: func.func @get_char
// CHECK: cir.string_constant "hello" : !cir.slice<i8>
// CHECK: cir.slice_elem
// CHECK-SAME: !cir.slice<i8>
