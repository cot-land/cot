// RUN: %cot emit-cir %s | %FileCheck %s

// Feature #051: Switch/match statement — ac syntax

enum Color { Red, Green, Blue }

fn color_to_int(c: Color) -> i32 {
    match c {
        Color.Red => return 1
        Color.Green => return 2
        Color.Blue => return 3
    }
    return 0
}

fn int_switch(x: i32) -> i32 {
    match x {
        0 => return 10
        1 => return 20
        2 => return 30
    }
    return 0
}

// CHECK-LABEL: func.func @color_to_int
// CHECK: cir.enum_value
// CHECK: cir.switch
// CHECK: return

// CHECK-LABEL: func.func @int_switch
// CHECK: cir.switch
// CHECK: return
