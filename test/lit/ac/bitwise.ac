// RUN: %cot emit-cir %s | %FileCheck %s

fn bitops(a: i32, b: i32) -> i32 {
    return a & b | a ^ b
}

fn bitnot(x: i32) -> i32 {
    return ~x
}

fn shifts(a: i32, b: i32) -> i32 {
    return a << b >> b
}

// CHECK-LABEL: func.func @bitops
// CHECK: cir.bit_and
// CHECK: cir.bit_xor
// CHECK: cir.bit_or

// CHECK-LABEL: func.func @bitnot
// CHECK: cir.bit_not

// CHECK-LABEL: func.func @shifts
// CHECK: cir.shl
// CHECK: cir.shr
