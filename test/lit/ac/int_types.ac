// RUN: %cot emit-cir %s | %FileCheck %s

fn narrow(x: i8) -> i8 {
    return x + x
}

fn wide(x: i64) -> i64 {
    return x + x
}

fn unsigned_add(a: u32, b: u32) -> u32 {
    return a + b
}

// CHECK-LABEL: func.func @narrow
// CHECK: cir.add %{{.*}}, %{{.*}} : i8

// CHECK-LABEL: func.func @wide
// CHECK: cir.add %{{.*}}, %{{.*}} : i64

// CHECK-LABEL: func.func @unsigned_add
// CHECK: cir.add %{{.*}}, %{{.*}} : i32
