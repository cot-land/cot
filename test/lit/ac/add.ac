// RUN: %cot emit-cir %s | %FileCheck %s

fn add(a: i32, b: i32) -> i32 {
    return a + b
}

fn main() -> i32 {
    return add(19, 23)
}

// CHECK-LABEL: func.func @add
// CHECK: cir.add %{{.*}}, %{{.*}} : i32
// CHECK: return

// CHECK-LABEL: func.func @main
