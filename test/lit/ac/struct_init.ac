// RUN: %cot emit-cir %s | %FileCheck %s

// Feature #025: Struct construction — ac syntax

struct Point {
    x: i32
    y: i32
}

fn make_point() -> Point {
    return Point { x: 19, y: 23 }
}

fn zero_point() -> Point {
    return Point { x: 0, y: 0 }
}

// CHECK-LABEL: func.func @make_point
// CHECK: cir.constant 19
// CHECK: cir.constant 23
// CHECK: cir.struct_init
// CHECK-SAME: !cir.struct<"Point", x: i32, y: i32>
// CHECK: return

// CHECK-LABEL: func.func @zero_point
// CHECK: cir.struct_init
// CHECK-SAME: !cir.struct<"Point", x: i32, y: i32>
