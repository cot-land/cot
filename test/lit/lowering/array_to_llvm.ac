// RUN: %cot emit-llvm %s | %FileCheck %s

// Feature #028-030: Array lowering — array_init → insertvalue, elem_val → extractvalue

fn get_second() -> i32 {
    let arr: [3]i32 = [10, 20, 30]
    return arr[1]
}

// CHECK-LABEL: llvm.func @get_second
// CHECK: llvm.mlir.undef : !llvm.array<3 x i32>
