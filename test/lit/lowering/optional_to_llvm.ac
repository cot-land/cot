// RUN: %cot emit-llvm %s | %FileCheck %s

// Features #041-044: Optional lowering
// ?i32 → !llvm.struct<(i32, i1)>
// null → {undef, false}
// wrap → {val, true}

fn get_null() -> ?i32 {
    let x: ?i32 = null
    return x
}

fn get_some() -> ?i32 {
    let y: ?i32 = 42
    return y
}

// CHECK-LABEL: llvm.func @get_null
// CHECK: llvm.mlir.undef : !llvm.struct<(i32, i1)>
// CHECK: llvm.mlir.constant(false)
// CHECK: llvm.insertvalue
// CHECK-SAME: [1]
// CHECK: llvm.return

// CHECK-LABEL: llvm.func @get_some
// CHECK: llvm.mlir.constant(42 : i32)
// CHECK: llvm.mlir.undef : !llvm.struct<(i32, i1)>
// CHECK: llvm.insertvalue
// CHECK-SAME: [0]
// CHECK: llvm.mlir.constant(true)
// CHECK: llvm.insertvalue
// CHECK-SAME: [1]
// CHECK: llvm.return
