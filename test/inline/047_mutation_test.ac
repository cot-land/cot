struct Point {
    x: i32,
    y: i32
}

fn get_x(p: Point) -> i32 {
    return p.x
}

test "field mutation via field_ptr" {
    var p: Point = Point { x: 1, y: 2 }
    p.x = 10
    assert(p.x == 10)
    assert(p.y == 2)
}

test "field mutation preserves other fields" {
    var p: Point = Point { x: 5, y: 7 }
    p.y = 99
    assert(p.x == 5)
    assert(p.y == 99)
}

test "array element mutation via elem_ptr" {
    var arr: [4]i32 = [1, 2, 3, 4]
    arr[2] = 99
    assert(arr[2] == 99)
    assert(arr[0] == 1)
}

test "unsigned extension via extui" {
    let x: u8 = 200
    let y: u32 = x as u32
    assert(y == 200)
}
