enum Color { Red, Green, Blue }

fn color_value(c: Color) -> i32 {
    let x: i32 = match c {
        Color.Red => 10
        Color.Green => 20
        Color.Blue => 30
    }
    return x
}

fn int_to_name(x: i32) -> i32 {
    let code: i32 = match x {
        0 => 100
        1 => 200
        2 => 300
    }
    return code
}

test "switch expr on enum" {
    assert(color_value(Color.Red) == 10)
    assert(color_value(Color.Green) == 20)
    assert(color_value(Color.Blue) == 30)
}

test "switch expr on integer" {
    assert(int_to_name(0) == 100)
    assert(int_to_name(1) == 200)
}

test "switch expr default" {
    assert(int_to_name(99) == 0)
}
