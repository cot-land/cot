// Feature 017: While loop — inline tests
// Run with: cot test test/inline/017_while_test.ac

test "sum 1 to 10" {
    var total: i32 = 0
    var i: i32 = 1
    while i <= 10 {
        total += i
        i += 1
    }
    assert(total == 55)
}

test "count down" {
    var x: i32 = 10
    while x > 0 {
        x -= 1
    }
    assert(x == 0)
}

test "while false" {
    var x: i32 = 42
    while 0 > 1 {
        x = 0
    }
    assert(x == 42)
}
