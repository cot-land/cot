@PACKAGE_INIT@

# CIRConfig.cmake — find_package(CIR) entry point
#
# Provides:
#   CIR::CIR — CIR dialect static library (MLIR dialect + types + ops)
#   CIR_INCLUDE_DIRS — path to CIR headers
#
# Usage:
#   find_package(CIR REQUIRED CONFIG)
#   target_link_libraries(my_frontend CIR::CIR)

# CIR requires MLIR
find_package(MLIR REQUIRED CONFIG)

set(CIR_INCLUDE_DIRS "${PACKAGE_PREFIX_DIR}/include")

if(NOT TARGET CIR::CIR)
  include("${CMAKE_CURRENT_LIST_DIR}/CIRTargets.cmake")
endif()
